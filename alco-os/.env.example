# ===== Supabase =====
# 既存ジビエ基幹と同じ Supabase プロジェクトを共有する（docs/09-gibier-integration.md 参照）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー側処理（ドラフト承認・監査ログ等）で使用。クライアントには絶対に出さない
SUPABASE_SERVICE_ROLE_KEY=

# ===== AI =====
# provider: anthropic | mock （モデル名をアプリ中にハードコードしない。切替はここだけ）
AI_PROVIDER=mock
AI_DEFAULT_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=

# ===== 受信箱API（/api/inbox）=====
# メール転送・iPhone共有ショートカット等の入口。長いランダム文字列を設定。
# SUPABASE_SERVICE_ROLE_KEY も必要（Supabase Dashboard → Settings → API Keys の Secret key）
INBOX_TOKEN=

# ===== LINE Bot（/api/line）=====
# LINE Developers → チャネル基本設定 → チャネルシークレット（署名検証に必須）
LINE_CHANNEL_SECRET=
# Messaging API設定 → チャネルアクセストークン（ALCO OSから返信する場合のみ）
LINE_CHANNEL_ACCESS_TOKEN=
# 既存のGAS秘書システムへ転送する場合のみ（Apps ScriptのウェブアプリURL）
GAS_WEBHOOK_URL=
